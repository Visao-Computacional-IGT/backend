APP_NAME=Lumen
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_SLACK_WEBHOOK_URL=

# Configuração MySQL (XAMPP ou RDS)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=facial_recognition
DB_USERNAME=root
DB_PASSWORD=

# Necessário para AWS RDS se SSL for exigido
# MYSQL_ATTR_SSL_CA=/caminho/para/global-bundle.pem

CACHE_DRIVER=file
QUEUE_CONNECTION=sync
